{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "event.schema.json",
  "title": "QueueEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "dedupeKey",
    "payload",
    "status",
    "attemptCount",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "enum": [
        "CHAT_REPLY",
        "MEMORY_EXTRACT",
        "DIARY_GENERATE",
        "PROACTIVE_SEND"
      ]
    },
    "dedupeKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "payload": {
      "type": "object"
    },
    "status": {
      "enum": [
        "PENDING",
        "PROCESSING",
        "RETRY_WAIT",
        "DONE",
        "DEAD"
      ]
    },
    "attemptCount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "nextAttemptAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "lockedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "lockedBy": {
      "type": [
        "string",
        "null"
      ]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "lastError": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}