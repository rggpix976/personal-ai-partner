{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "chat-result.schema.json",
  "title": "ChatResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "status",
    "requestId",
    "warnings"
  ],
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "status": {
      "enum": [
        "completed",
        "queued",
        "failed"
      ]
    },
    "requestId": {
      "type": "string"
    },
    "userMessage": {
      "$ref": "#/$defs/messageDto"
    },
    "assistantMessage": {
      "$ref": "#/$defs/messageDto"
    },
    "retryAfterSeconds": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "error": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "messageDto": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "messageId",
        "createdAt",
        "role",
        "messageType",
        "text",
        "status"
      ],
      "properties": {
        "messageId": {
          "type": "string"
        },
        "requestId": {
          "type": [
            "string",
            "null"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "role": {
          "enum": [
            "user",
            "assistant",
            "system"
          ]
        },
        "messageType": {
          "enum": [
            "text",
            "image",
            "proactive",
            "error"
          ]
        },
        "text": {
          "type": "string"
        },
        "image": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": [
            "name",
            "mimeType",
            "summary"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "mimeType": {
              "enum": [
                "image/jpeg",
                "image/png",
                "image/webp"
              ]
            },
            "summary": {
              "type": "string"
            }
          }
        },
        "status": {
          "enum": [
            "accepted",
            "completed",
            "failed"
          ]
        },
        "error": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": [
            "code",
            "message"
          ],
          "properties": {
            "code": {
              "type": "string"
            },
            "message": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}