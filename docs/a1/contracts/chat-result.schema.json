{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acepilot.local/schemas/chat-result.schema.json",
  "title": "ChatResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "status",
    "requestId",
    "warnings"
  ],
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "status": {
      "enum": [
        "completed",
        "routed",
        "queued",
        "failed"
      ]
    },
    "requestId": {
      "type": "string",
      "format": "uuid"
    },
    "userMessage": {
      "oneOf": [
        {
          "$ref": "#/$defs/messageDto"
        },
        {
          "type": "null"
        }
      ]
    },
    "assistantMessage": {
      "oneOf": [
        {
          "$ref": "#/$defs/messageDto"
        },
        {
          "type": "null"
        }
      ]
    },
    "retryAfterSeconds": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "error": {
      "oneOf": [
        {
          "$ref": "#/$defs/errorDto"
        },
        {
          "type": "null"
        }
      ]
    },
    "route": {
      "oneOf": [
        {
          "$ref": "#/$defs/nonCharacterRoute"
        },
        {
          "type": "null"
        }
      ]
    },
    "notice": {
      "oneOf": [
        {
          "$ref": "#/$defs/noticeDto"
        },
        {
          "type": "null"
        }
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "completed"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "userMessage",
          "assistantMessage"
        ],
        "properties": {
          "ok": {
            "const": true
          },
          "userMessage": {
            "$ref": "#/$defs/messageDto"
          },
          "assistantMessage": {
            "$ref": "#/$defs/messageDto"
          },
          "route": {
            "type": "null"
          },
          "notice": {
            "type": "null"
          },
          "error": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "routed"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "userMessage",
          "assistantMessage",
          "retryAfterSeconds",
          "error",
          "route",
          "notice"
        ],
        "properties": {
          "ok": {
            "const": true
          },
          "userMessage": {
            "$ref": "#/$defs/messageDto"
          },
          "assistantMessage": {
            "type": "null"
          },
          "retryAfterSeconds": {
            "type": "null"
          },
          "error": {
            "type": "null"
          },
          "route": {
            "$ref": "#/$defs/nonCharacterRoute"
          },
          "notice": {
            "$ref": "#/$defs/noticeDto"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "queued"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "userMessage",
          "retryAfterSeconds"
        ],
        "properties": {
          "ok": {
            "const": true
          },
          "userMessage": {
            "$ref": "#/$defs/messageDto"
          },
          "retryAfterSeconds": {
            "type": "integer",
            "minimum": 1
          },
          "assistantMessage": {
            "type": "null"
          },
          "route": {
            "type": "null"
          },
          "notice": {
            "type": "null"
          },
          "error": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "failed"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "error"
        ],
        "properties": {
          "ok": {
            "const": false
          },
          "route": {
            "type": "null"
          },
          "notice": {
            "type": "null"
          },
          "error": {
            "$ref": "#/$defs/errorDto"
          }
        }
      }
    }
  ],
  "$defs": {
    "errorDto": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "nonCharacterRoute": {
      "enum": [
        "PRODUCT_INFO",
        "ADMIN_OOC"
      ]
    },
    "noticeDto": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "message"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    },
    "characterApprovalMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "source",
        "policyVersion",
        "profileSchemaVersion",
        "profileRevision",
        "catalogVersion",
        "characterPackId",
        "characterPackVersion"
      ],
      "properties": {
        "surface": {
          "$ref": "immersion-guard-decision.schema.json#/$defs/surface"
        },
        "source": {
          "enum": [
            "generated",
            "rewrite",
            "canonical",
            "fallback",
            "legacy_revalidated"
          ]
        },
        "policyVersion": {
          "const": "character-policy.v2"
        },
        "profileSchemaVersion": {
          "const": "character-profile.v2"
        },
        "profileRevision": {
          "type": "integer",
          "minimum": 1
        },
        "catalogVersion": {
          "const": "character-catalog.v2"
        },
        "characterPackId": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
        },
        "characterPackVersion": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9.-]{2,79}$"
        }
      }
    },
    "messageDto": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "messageId",
        "requestId",
        "createdAt",
        "role",
        "messageType",
        "text",
        "image",
        "status",
        "replyToMessageId",
        "model",
        "inputTokens",
        "outputTokens",
        "error",
        "characterApproval"
      ],
      "properties": {
        "messageId": {
          "type": "string",
          "format": "uuid"
        },
        "requestId": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "role": {
          "enum": [
            "user",
            "assistant",
            "system"
          ]
        },
        "messageType": {
          "enum": [
            "text",
            "image",
            "proactive",
            "error"
          ]
        },
        "text": {
          "type": "string"
        },
        "image": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "mimeType",
                "summary"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "mimeType": {
                  "enum": [
                    "image/jpeg",
                    "image/png",
                    "image/webp"
                  ]
                },
                "summary": {
                  "type": "string"
                }
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "enum": [
            "accepted",
            "completed",
            "failed"
          ]
        },
        "replyToMessageId": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        },
        "inputTokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "outputTokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "error": {
          "oneOf": [
            {
              "$ref": "#/$defs/errorDto"
            },
            {
              "type": "null"
            }
          ]
        },
        "characterApproval": {
          "oneOf": [
            {
              "$ref": "#/$defs/characterApprovalMetadata"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  }
}
