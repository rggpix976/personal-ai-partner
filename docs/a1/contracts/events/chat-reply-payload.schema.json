{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acepilot.local/schemas/events/chat-reply-payload.schema.json",
  "title": "ChatReplyPayload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "requestId",
    "userMessageId",
    "requestedAt"
  ],
  "properties": {
    "requestId": {
      "type": "string",
      "format": "uuid"
    },
    "userMessageId": {
      "type": "string",
      "format": "uuid"
    },
    "requestedAt": {
      "type": "string",
      "format": "date-time"
    },
    "characterRuntimeMode": {
      "enum": [
        "legacy",
        "enforced"
      ]
    },
    "characterBinding": {
      "oneOf": [
        {
          "$ref": "#/$defs/characterBinding"
        },
        {
          "type": "null"
        }
      ]
    },
    "completionRoute": {
      "enum": [
        "PRODUCT_INFO",
        "ADMIN_OOC"
      ]
    },
    "manualRequestId": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "originalEventId": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "image": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tempFileId",
            "name",
            "mimeType",
            "expiresAt"
          ],
          "properties": {
            "tempFileId": {
              "type": "string",
              "minLength": 1
            },
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 255
            },
            "mimeType": {
              "enum": [
                "image/jpeg",
                "image/png",
                "image/webp"
              ]
            },
            "expiresAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "characterRuntimeMode"
        ],
        "properties": {
          "characterRuntimeMode": {
            "const": "enforced"
          }
        }
      },
      "then": {
        "required": [
          "characterBinding"
        ],
        "properties": {
          "characterBinding": {
            "$ref": "#/$defs/characterBinding"
          }
        }
      },
      "else": {
        "properties": {
          "characterBinding": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "manualRequestId"
        ],
        "properties": {
          "manualRequestId": {
            "type": "string"
          }
        }
      },
      "then": {
        "required": [
          "originalEventId"
        ],
        "properties": {
          "originalEventId": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "originalEventId"
        ],
        "properties": {
          "originalEventId": {
            "type": "string"
          }
        }
      },
      "then": {
        "required": [
          "manualRequestId"
        ],
        "properties": {
          "manualRequestId": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "completionRoute"
        ]
      },
      "then": {
        "required": [
          "characterRuntimeMode",
          "characterBinding"
        ],
        "properties": {
          "characterRuntimeMode": {
            "const": "enforced"
          },
          "characterBinding": {
            "$ref": "#/$defs/characterBinding"
          }
        }
      }
    }
  ],
  "$defs": {
    "characterBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policyVersion",
        "profileSchemaVersion",
        "profileRevision",
        "catalogVersion",
        "characterPackId",
        "characterPackVersion"
      ],
      "properties": {
        "policyVersion": {
          "const": "character-policy.v2"
        },
        "profileSchemaVersion": {
          "const": "character-profile.v2"
        },
        "profileRevision": {
          "type": "integer",
          "minimum": 1
        },
        "catalogVersion": {
          "const": "character-catalog.v2"
        },
        "characterPackId": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
        },
        "characterPackVersion": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9.-]{2,79}$"
        }
      }
    }
  }
}
