{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acepilot.local/schemas/events/chat-reply-payload.schema.json",
  "title": "ChatReplyPayload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "requestId",
    "userMessageId",
    "requestedAt"
  ],
  "properties": {
    "requestId": {
      "type": "string",
      "format": "uuid"
    },
    "userMessageId": {
      "type": "string",
      "format": "uuid"
    },
    "requestedAt": {
      "type": "string",
      "format": "date-time"
    },
    "image": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tempFileId",
            "name",
            "mimeType",
            "expiresAt"
          ],
          "properties": {
            "tempFileId": {
              "type": "string",
              "minLength": 1
            },
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 255
            },
            "mimeType": {
              "enum": [
                "image/jpeg",
                "image/png",
                "image/webp"
              ]
            },
            "expiresAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
