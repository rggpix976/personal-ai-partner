{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acepilot.local/schemas/events/memory-extract-payload.schema.json",
  "title": "MemoryExtractPayload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "firstMessageId",
    "lastMessageId",
    "sourceMessageIds",
    "requestedAt"
  ],
  "properties": {
    "firstMessageId": {
      "type": "string",
      "format": "uuid"
    },
    "lastMessageId": {
      "type": "string",
      "format": "uuid"
    },
    "sourceMessageIds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "requestedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
