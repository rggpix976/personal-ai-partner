{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acepilot.local/schemas/memory-candidate.schema.json",
  "title": "MemoryCandidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action",
    "category",
    "normalizedKey",
    "content",
    "confidence",
    "sourceMessageIds",
    "reason"
  ],
  "properties": {
    "action": {
      "enum": [
        "create",
        "confirm",
        "update",
        "ignore"
      ]
    },
    "category": {
      "enum": [
        "profile",
        "preference",
        "relationship",
        "interest",
        "goal",
        "event",
        "promise",
        "other"
      ]
    },
    "normalizedKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "sourceMessageIds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "existingMemoryId": {
      "type": "string",
      "format": "uuid"
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "action": {
            "const": "create"
          }
        },
        "required": [
          "action"
        ]
      },
      "then": {
        "not": {
          "required": [
            "existingMemoryId"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "enum": [
              "confirm",
              "update"
            ]
          }
        },
        "required": [
          "action"
        ]
      },
      "then": {
        "required": [
          "existingMemoryId"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "ignore"
          }
        },
        "required": [
          "action"
        ]
      },
      "then": {
        "not": {
          "required": [
            "existingMemoryId"
          ]
        }
      }
    }
  ]
}
